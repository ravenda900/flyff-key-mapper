{
  "manifest_version": 3,
  "name": "Flyff Utility",
  "description": "Unified Flyff utilities for key mapping and key trigger workflows.",
  "version": "3.0.0",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "notifications"],
  "host_permissions": ["https://universe.flyff.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://universe.flyff.com/play*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "root.png",
        "stun.png",
        "full-hp-character-window-no-text-hp-bar.png",
        "full-hp-character-window-percentage-hp-bar.png",
        "full-hp-character-window-raw-hp-values-in-hp-bar.png",
        "not-full-hp-character-window-no-text-hp-bar.png",
        "not-full-hp-character-window-percentage-hp-bar.png",
        "not-full-hp-character-window-raw-hp-values-in-hp-bar.png",
        "button_image.png",
        "button_image2.png",
        "tesseract-worker.min.js"
      ],
      "matches": ["https://universe.flyff.com/*"]
    }
  ],
  "commands": {
    "toggle-mapper": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Toggle Flyff Utility overlay"
    }
  },
  "icons": {
    "16": "flyff-u.png",
    "32": "flyff-u.png",
    "48": "flyff-u.png",
    "128": "flyff-u.png"
  },
  "action": {
    "default_title": "Flyff Utility"
  }
}
